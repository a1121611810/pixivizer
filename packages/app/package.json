{
  "name": "pictelio-app",
  "version": "3.15.0",
  "private": true,
  "description": "Pictelio SPA - Pixiv illustration browser built with SolidJS + Capacitor",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "check": "vp check",
    "preview": "vp preview",
    "test": "vp test",
    "test:watch": "vitest",
    "test:browser": "vitest run -c vitest.browser.config.ts",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=tests/e2e/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=tests/e2e/playwright.config.ts --debug",
    "test:all": "pnpm test && pnpm test:browser",
    "lint": "vp lint",
    "fmt": "vp fmt --write",
    "fmt:check": "vp fmt --check",
    "cap:init": "pnpm exec cap init pictelio io.pictelio.app",
    "cap:add:android": "pnpm exec cap add android",
    "cap:copy": "pnpm exec cap copy",
    "cap:sync": "pnpm exec cap sync",
    "cap:open:android": "pnpm exec cap open android",
    "sync:android-version": "node scripts/sync-android-version.mjs",
    "sync:credentials": "node scripts/sync-credentials.mjs",
    "build:android": "pnpm run sync:android-version && pnpm run sync:credentials && pnpm run build && pnpm run cap:sync && cd android && GRADLE_USER_HOME=$(pwd)/.gradle ./gradlew assembleDebug",
    "build:android:release": "pnpm run sync:android-version && pnpm run sync:credentials && pnpm run build && pnpm run cap:sync && cd android && GRADLE_USER_HOME=$(pwd)/.gradle ./gradlew assembleRelease",
    "release:github": "node scripts/release-github.mjs",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run",
    "dev:android": "node scripts/dev-android.mjs",
    "generate:icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "8.0.0",
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "@capacitor/device": "^8.0.3",
    "@capacitor/preferences": "^8.0.1",
    "@chenglou/pretext": "^0.0.8",
    "@fluentui/tokens": "1.0.0-alpha.23",
    "@fluentui/web-components": "3.0.2",
    "@solid-primitives/intersection-observer": "^2.2.5",
    "@solid-primitives/scheduled": "^1.5.3",
    "@solid-primitives/scroll": "^2.1.6",
    "@tanstack/solid-db": "^0.2.30",
    "@tanstack/solid-query": "^5.101.2",
    "@tanstack/solid-router": "1.170.18",
    "@tanstack/solid-virtual": "^3.13.33",
    "comlink": "^4.4.2",
    "jszip": "^3.10.1",
    "ora": "^9.4.1",
    "solid-js": "^1.9.14",
    "spark-md5": "^3.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@solidjs/testing-library": "^0.8.10",
    "@types/node": "^26.1.1",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "canvas": "^3.2.3",
    "happy-dom": "^20.11.0",
    "https-proxy-agent": "^9.1.0",
    "jsdom": "^29.1.1",
    "json5": "^2.2.3",
    "modern-css-reset": "^1.4.0",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "unocss": "^66.7.5",
    "vite": "^8.1.5",
    "vite-plugin-solid": "^2.11.13",
    "vite-plus": "^0.2.5",
    "vitest": "^4.1.10"
  }
}
