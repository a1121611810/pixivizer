// ─────────────────────────────────────────────────────────────
// Pictelio — Pixiv OAuth 与运行时配置（单一事实源）
// VS Code 等编辑器原生支持 JSON5 语法高亮
// ─────────────────────────────────────────────────────────────
// 设计决策     → docs/adr/001-unified-config.md
// Java 生成逻辑 → scripts/sync-credentials.mjs
// JS 注入      → vite.config.ts（__CREDENTIALS__ / __PUBLIC_CONFIG__）
// ─────────────────────────────────────────────────────────────

{
  // ═══════════════════════════════════════════════════════════
  // A — OAuth 凭证（机密！仅 JS DEV 分支引用，生产被 tree-shake 消除）
  // ═══════════════════════════════════════════════════════════
  clientId: "MOBrBDS8blbauoSck0ZfDbtuzpyT",
  clientSecret: "lsACyCD94FhDUtGTXi3QzcFE2uU1hqtDaKeqrdwj",
  hashSecret: "28c1fdd170a5204386cb1313c7077b34f83e4aaf4aa829ce78c231e05b0bae2c",

  // ═══════════════════════════════════════════════════════════
  // B — 请求头伪装（模拟 Pixiv iOS 客户端）
  // ═══════════════════════════════════════════════════════════
  userAgent: "PixivIOSApp/7.18.3 (iOS 18.5; iPhone15,4)",
  appOs: "ios",
  appOsVersion: "18.5",

  // ═══════════════════════════════════════════════════════════
  // C — 端点 URL
  // ═══════════════════════════════════════════════════════════
  authUrl: "https://oauth.secure.pixiv.net/auth/token",
  apiBaseUrl: "https://app-api.pixiv.net",
  loginUrl: "https://app-api.pixiv.net/web/v1/login",
  redirectUri: "https://app-api.pixiv.net/web/v1/users/auth/pixiv/callback",
  imageCdnUrl: "https://i.pximg.net",

  // ═══════════════════════════════════════════════════════════
  // D — 请求头固定值
  // ═══════════════════════════════════════════════════════════
  referer: "https://app-api.pixiv.net/",
  contentType: "application/x-www-form-urlencoded",

  // ═══════════════════════════════════════════════════════════
  // E — 超时设置（毫秒），全局默认值 + 局部覆盖
  // ═══════════════════════════════════════════════════════════
  timeout: {
    connect: 15000, // 全局连接超时
    read: 30000, // 全局读取超时
    overrides: {
      imageProxy: { connect: 10000, read: 15000 }, // 图片代理短连接，尽快失败
      dnsQuery: { connect: 5000, read: 5000 }, // DoH DNS 超短超时
      oauthDialog: { read: 120000 }, // OAuth WebView 弹窗长超时
    },
  },

  // ═══════════════════════════════════════════════════════════
  // F — Android 平台配置
  // ═══════════════════════════════════════════════════════════
  minWebviewVersion: 85, // WebView 最低主版本
  cacheDir: "pictelio-images", // 图片缓存子目录名
  cacheMaxBytes: 314572800, // 300 MB
  dohUrl: "https://cloudflare-dns.com/dns-query?name=",
  allowedHosts: ["app-api.pixiv.net", "i.pximg.net"],
}
