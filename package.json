{
  "name": "pictelio",
  "version": "1.5.6",
  "private": true,
  "description": "Pictelio monorepo - SolidJS Pixiv browser + landing page",
  "homepage": "https://a1121611810.github.io/pixivizer",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter pictelio-app dev",
    "build": "pnpm --filter pictelio-app build",
    "check": "pnpm --filter pictelio-app check",
    "preview": "pnpm --filter pictelio-app preview",
    "test": "pnpm --filter pictelio-app test",
    "test:watch": "pnpm --filter pictelio-app test:watch",
    "test:browser": "pnpm --filter pictelio-app test:browser",
    "test:e2e": "pnpm --filter pictelio-app test:e2e",
    "test:e2e:ui": "pnpm --filter pictelio-app test:e2e:ui",
    "test:all": "pnpm test && pnpm test:browser",
    "lint": "pnpm --filter pictelio-app lint",
    "fmt": "pnpm --filter pictelio-app fmt",
    "fmt:check": "pnpm --filter pictelio-app fmt:check",
    "build:android": "pnpm --filter pictelio-app build:android",
    "build:android:release": "pnpm --filter pictelio-app build:android:release",
    "release:github": "pnpm --filter pictelio-app release:github",
    "release": "pnpm --filter pictelio-app release",
    "release:dry": "pnpm --filter pictelio-app release:dry",
    "deploy": "node scripts/deploy.mjs",
    "deploy:dry": "node scripts/deploy.mjs --dry-run"
  },
  "packageManager": "pnpm@11.9.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "error"
    }
  }
}
