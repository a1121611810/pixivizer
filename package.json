{
  "name": "pictelio",
  "version": "1.4.0",
  "private": true,
  "description": "A third-party Pixiv illustration browser built with SolidJS, packaged as a native Android app with Capacitor",
  "homepage": "https://a1121611810.github.io/pixivizer",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build",
    "check": "vp check",
    "preview": "vp preview",
    "test": "vp test",
    "test:watch": "vitest",
    "lint": "vp lint",
    "fmt": "vp fmt --write",
    "fmt:check": "vp fmt --check",
    "cap:init": "pnpm exec cap init pictelio io.pictelio.app",
    "cap:add:android": "pnpm exec cap add android",
    "cap:copy": "pnpm exec cap copy",
    "cap:sync": "pnpm exec cap sync",
    "cap:open:android": "pnpm exec cap open android",
    "sync:android-version": "node scripts/sync-android-version.mjs",
    "build:android": "pnpm run sync:android-version && pnpm run build && pnpm run cap:sync && cd android && ./gradlew assembleDebug",
    "build:android:release": "pnpm run sync:android-version && pnpm run build && pnpm run cap:sync && cd android && ./gradlew assembleRelease",
    "release:github": "node scripts/release-github.mjs",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run",
    "dev:android": "node scripts/dev-android.mjs",
    "generate:icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/device": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@solidjs/router": "^0.16.1",
    "capacitor-secure-storage-plugin": "^0.13.0",
    "https-proxy-agent": "^9.1.0",
    "jszip": "^3.10.1",
    "solid-js": "^1.9.13",
    "spark-md5": "^3.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^26.0.0",
    "happy-dom": "^20.10.6",
    "modern-css-reset": "^1.4.0",
    "playwright": "^1.61.1",
    "postcss-pxtorem": "^6.1.0",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vite-plus": "^0.2.1",
    "vitest": "^4.1.9"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "error"
    }
  }
}
